# Copy to .env and fill in real values. Do NOT commit your .env.

# Database
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_pass
POSTGRES_DB=finance_db

# API Security
# Generate with: openssl rand -hex 32
# Required to be a strong (non-placeholder) value in live mode.
SECRET_KEY=replace-me-with-openssl-rand-hex-32
# Fernet key for encrypting bank tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-me-with-a-fernet-key

# TrueLayer Open Banking (get from https://console.truelayer.com/)
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:8000/api/v1/banking/callback
# true = TrueLayer sandbox; false = live banking data
TRUELAYER_SANDBOX=true

# Environment
ENVIRONMENT=development
