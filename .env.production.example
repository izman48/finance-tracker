# Copy to .env.production ON THE SERVER and fill in. Never commit the real file.

# Public hostname (DNS A record must point at the server; Caddy gets HTTPS certs automatically)
DOMAIN=finance.example.com

# Database — pick a strong password, it is not exposed outside Docker
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=
POSTGRES_DB=finance_db

# Generate with: openssl rand -hex 32
SECRET_KEY=
# Generate with: docker run --rm python:3.12-slim python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# TrueLayer (https://console.truelayer.com/)
# Register https://<DOMAIN>/api/v1/banking/callback as a redirect URI in the console.
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_SANDBOX=true
